{
  "name": "modelkombat",
  "private": true,
  "version": "0.1.0",
  "description": "A platform where LLM-authored fighters battle in a deterministic stickman ring.",
  "type": "module",
  "scripts": {
    "vercel:dev": "vercel dev",
    "dev:web": "vite web",
    "build": "tsc -p tsconfig.build.json",
    "build:web": "vite build web",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.api.json && tsc --noEmit -p web/tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "mutation": "stryker run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "fight": "tsx src/cli/fight.ts",
    "benchmark": "tsx src/cli/benchmark.ts",
    "gen:spec": "tsx src/cli/write-spec.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.20.0",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.9",
    "ajv": "^8.20.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "marked": "^18.0.5",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "solid-js": "^1.9.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  }
}
