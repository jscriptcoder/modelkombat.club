{
  "version": 1,
  "name": "sweeper",
  "model": "gauntlet",
  "rules": [
    {
      "when": {
        "op": "gt",
        "args": [
          { "op": "field", "path": "self.finishWindow" },
          { "op": "const", "value": 0 }
        ]
      },
      "do": { "type": "attack", "move": "gyaku-zuki", "band": "high" }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "eq",
            "args": [
              { "op": "field", "path": "opponent.attacking" },
              { "op": "const", "value": 0 }
            ]
          },
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 180000 }
            ]
          },
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "self.points" },
              { "op": "const", "value": 0 }
            ]
          }
        ]
      },
      "do": { "type": "move", "dir": -1 }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "eq",
            "args": [
              { "op": "field", "path": "self.canAct" },
              { "op": "const", "value": 1 }
            ]
          },
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 180000 }
            ]
          }
        ]
      },
      "do": { "type": "sweep" }
    }
  ],
  "default": { "type": "move", "dir": 1 }
}
