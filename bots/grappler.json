{
  "version": 1,
  "name": "grappler",
  "rules": [
    {
      "when": {
        "op": "eq",
        "args": [
          { "op": "field", "path": "opponent.throwing" },
          { "op": "const", "value": 1 }
        ]
      },
      "do": { "type": "throw-break" }
    },
    {
      "when": {
        "op": "and",
        "args": [
          {
            "op": "eq",
            "args": [
              { "op": "field", "path": "self.canAct" },
              { "op": "const", "value": 1 }
            ]
          },
          {
            "op": "lte",
            "args": [
              { "op": "field", "path": "opponent.distance" },
              { "op": "const", "value": 130000 }
            ]
          }
        ]
      },
      "do": { "type": "throw" }
    }
  ],
  "default": { "type": "move", "dir": 1 }
}
